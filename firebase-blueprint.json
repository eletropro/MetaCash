{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "tenantId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Tenant": {
      "title": "Tenant (Sports Center)",
      "description": "Information about a sports center",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "ownerId": { "type": "string" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "Court": {
      "title": "Court",
      "description": "A sports court within a tenant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "basePrice": { "type": "number" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "tenantId", "name", "basePrice"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A court reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "courtId": { "type": "string" },
        "userId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "paid"] },
        "totalPrice": { "type": "number" }
      },
      "required": ["id", "tenantId", "courtId", "userId", "startTime", "endTime", "status", "totalPrice"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "UserProfile", "description": "User profiles" },
    "/tenants/{tenantId}": { "schema": "Tenant", "description": "Sports centers" },
    "/tenants/{tenantId}/courts/{courtId}": { "schema": "Court", "description": "Courts per tenant" },
    "/tenants/{tenantId}/bookings/{bookingId}": { "schema": "Booking", "description": "Bookings per tenant" },
    "/tenants/{tenantId}/coupons/{couponId}": { "schema": "Coupon", "description": "Coupons per tenant" }
  }
}
