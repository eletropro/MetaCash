rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "duhgostozo@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isTenantOwner(tenantId) {
      return isAuthenticated() && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'client'] &&
             data.createdAt is string;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['tenantId', 'courtId', 'userId', 'startTime', 'endTime', 'status', 'totalPrice']) &&
             data.tenantId is string &&
             data.courtId is string &&
             data.userId is string &&
             data.status in ['pending', 'confirmed', 'cancelled', 'paid'] &&
             data.totalPrice is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /tenants/{tenantId} {
      allow read: if true; // Publicly readable for discovery
      allow create: if isAdmin();
      allow update: if isAdmin() || isTenantOwner(tenantId);
      
      match /courts/{courtId} {
        allow read: if true;
        allow write: if isAdmin() || isTenantOwner(tenantId);
      }
      
      match /bookings/{bookingId} {
        allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isTenantOwner(tenantId) || isAdmin());
        allow create: if isAuthenticated() && isValidBooking(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update: if isAuthenticated() && (isOwner(resource.data.userId) || isTenantOwner(tenantId) || isAdmin());
      }
      
      match /coupons/{couponId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || isTenantOwner(tenantId);
      }
    }
  }
}
