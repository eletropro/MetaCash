rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "duhgostozo@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isTenantOwner(tenantId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'client'] &&
             data.createdAt is string;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['tenantId', 'courtId', 'userId', 'startTime', 'endTime', 'status', 'totalPrice']) &&
             data.tenantId is string &&
             data.courtId is string &&
             data.userId is string &&
             data.status in ['pending', 'confirmed', 'cancelled', 'paid'] &&
             data.totalPrice is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == "duhgostozo@gmail.com";
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if isAdmin() || isTenantOwner(tenantId);
      
      match /{allSubcollections=**} {
        allow read, write: if isAdmin() || isTenantOwner(tenantId);
      }

      match /courts/{courtId} {
        allow read: if true;
      }
      
      match /bookings/{bookingId} {
        allow read: if isAuthenticated() && (
          resource.data.status in ['confirmed', 'paid'] || 
          isOwner(resource.data.userId) || 
          isAdmin()
        );
        allow create: if isAuthenticated() && isValidBooking(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update: if isAuthenticated() && (
          isAdmin() || 
          (isOwner(resource.data.userId) && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && 
           request.resource.data.status == 'cancelled')
        );
      }
      
      match /plans/{planId} {
        allow read: if true;
      }
    }
  }
}
