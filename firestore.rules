rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function requestMatchesUid() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Transactions
    match /transactions/{docId} {
      allow read: if isDocOwner();
      allow create: if requestMatchesUid();
      allow update: if isDocOwner() && requestMatchesUid();
      allow delete: if isDocOwner();
    }

    // Budgets
    match /budgets/{docId} {
      allow read: if isDocOwner();
      allow create: if requestMatchesUid();
      allow update: if isDocOwner() && requestMatchesUid();
      allow delete: if isDocOwner();
    }

    // Customers
    match /customers/{docId} {
      allow read: if isDocOwner();
      allow create: if requestMatchesUid();
      allow update: if isDocOwner() && requestMatchesUid();
      allow delete: if isDocOwner();
    }

    // Loans
    match /loans/{docId} {
      allow read: if isDocOwner();
      allow create: if requestMatchesUid();
      allow update: if isDocOwner() && requestMatchesUid();
      allow delete: if isDocOwner();
    }
  }
}
